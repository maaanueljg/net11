rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users' private team data
    // Solo el dueño puede leer/escribir su equipo
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Public ranking
    // Todos pueden ver el ranking, solo el dueño puede actualizar su entrada
    match /ranking/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Private leagues
    // Todos los autenticados pueden leer, solo miembros pueden escribir
    match /leagues/{leagueCode} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null 
                    && request.auth.uid in resource.data.members;
    }
  }
}
