{
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", ".firebaserc", "docs/**", "firestore.rules", "*.md"],
    "rewrites": [
      { "source": "/join/**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**/*.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ]
  }
}
